# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
TG_API_ID=your_telegram_api_id
TG_API_HASH=your_telegram_api_hash
BOT_NAME=your_bot_username

# PostgreSQL (main database)
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_PORT=5432
DB_NAME=your_db_name

# PostgreSQL (log database)
DBLOG_NAME=your_log_db_name

# OpenAI — story generation (GPT-4o) and NPC dialogue
# Read automatically from environment by the openai SDK
OPENAI_API_KEY=your_openai_api_key_here

# Google API — Translation API
GGL_API_KEY=your_google_api_key_here

